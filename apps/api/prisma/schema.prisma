generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum VerificationType {
  CRIMINAL
  EMPLOYMENT
  EDUCATION
  ADDRESS
  INSURANCE
}

enum VerificationStatus {
  DRAFT
  PENDING_EMPLOYEE_SUBMISSION
  PENDING_CLIENT_REVIEW
  IN_CART
  PENDING_PAYMENT
  PENDING_PAYMENT_VERIFICATION
  ADMIN_QUEUE
  IN_PROGRESS
  PENDING_ADMIN_REVIEW
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
}

enum FieldAgentStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

// ─── Core User Models (better-auth compatible) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?   @unique
  // better-auth admin plugin fields
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  // Tasdeeq-specific fields
  isSuperAdmin  Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions          Session[]
  accounts          Account[]
  corporateProfile  CorporateUser?
  consumerProfile   Consumer?
  fieldAgentProfile FieldAgent?
  auditLogs         AuditLog[]

  @@map("users")
}

// ─── Better-auth Session / Account / Verification ────────────────────────────

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verifications")
}

// ─── Domain Profile Models ────────────────────────────────────────────────────

model CorporateUser {
  id        String  @id @default(cuid())
  userId    String  @unique
  companyId String
  isAdmin   Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@map("corporate_users")
}

model Company {
  id                   String   @id @default(cuid())
  name                 String
  registrationNo       String?
  address              String?
  isEducationInstitute Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users             CorporateUser[]
  verificationItems VerificationItem[]

  @@map("companies")
}

model Consumer {
  id     String  @id @default(cuid())
  userId String  @unique
  cnic   String?

  user              User               @relation(fields: [userId], references: [id])
  verificationItems VerificationItem[]

  @@map("consumers")
}

model FieldAgent {
  id        String           @id @default(cuid())
  userId    String           @unique
  cnic      String
  latitude  Float?
  longitude Float?
  status    FieldAgentStatus @default(PENDING_APPROVAL)
  createdAt DateTime         @default(now())

  user  User               @relation(fields: [userId], references: [id])
  tasks VerificationItem[]

  @@map("field_agents")
}

// ─── Verification Models ──────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String
  cnic      String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())

  verificationItems VerificationItem[]

  @@map("subjects")
}

model VerificationItem {
  id               String             @id @default(cuid())
  subjectId        String
  verificationType VerificationType
  status           VerificationStatus @default(DRAFT)
  companyId        String?
  consumerId       String?
  fieldAgentId     String?
  invoiceId        String?
  selfReportToken  String?            @unique
  selfReportExpiry DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  subject        Subject         @relation(fields: [subjectId], references: [id])
  company        Company?        @relation(fields: [companyId], references: [id])
  consumer       Consumer?       @relation(fields: [consumerId], references: [id])
  fieldAgent     FieldAgent?     @relation(fields: [fieldAgentId], references: [id])
  invoice        Invoice?        @relation(fields: [invoiceId], references: [id])
  documents      Document[]
  statusHistory  StatusHistory[]
  employmentData EmploymentData?
  educationData  EducationData?
  addressData    AddressData?

  @@map("verification_items")
}

model StatusHistory {
  id                 String             @id @default(cuid())
  verificationItemId String
  status             VerificationStatus
  actorId            String?
  remarks            String?
  createdAt          DateTime           @default(now())

  verificationItem VerificationItem @relation(fields: [verificationItemId], references: [id])

  @@map("status_history")
}

// ─── Verification Data Models ─────────────────────────────────────────────────

model EmploymentData {
  id                  String    @id @default(cuid())
  verificationItemId  String    @unique
  employerName        String?
  employerContact     String?
  jobTitle            String?
  startDate           DateTime?
  endDate             DateTime?
  reasonForLeaving    String?
  remarks             String?
  submittedByEmployee Boolean   @default(false)

  verificationItem VerificationItem @relation(fields: [verificationItemId], references: [id])

  @@map("employment_data")
}

model EducationData {
  id                  String    @id @default(cuid())
  verificationItemId  String    @unique
  instituteName       String?
  degree              String?
  fieldOfStudy        String?
  startDate           DateTime?
  endDate             DateTime?
  result              String?
  remarks             String?
  submittedByEmployee Boolean   @default(false)

  verificationItem VerificationItem @relation(fields: [verificationItemId], references: [id])

  @@map("education_data")
}

model AddressData {
  id                 String    @id @default(cuid())
  verificationItemId String    @unique
  address            String?
  city               String?
  agentRemarks       String?
  latitude           Float?
  longitude          Float?
  visitedAt          DateTime?

  verificationItem VerificationItem @relation(fields: [verificationItemId], references: [id])

  @@map("address_data")
}

// ─── Payment Models ───────────────────────────────────────────────────────────

model Invoice {
  id            String         @id @default(cuid())
  totalAmount   Decimal
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus  @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items    VerificationItem[]
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id             String        @id @default(cuid())
  invoiceId      String
  amount         Decimal
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionRef String?
  verifiedById   String?
  verifiedAt     DateTime?
  createdAt      DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

// ─── Supporting Models ────────────────────────────────────────────────────────

model Document {
  id                 String   @id @default(cuid())
  verificationItemId String
  fileName           String
  mimeType           String
  storageKey         String
  uploadedById       String?
  createdAt          DateTime @default(now())

  verificationItem VerificationItem @relation(fields: [verificationItemId], references: [id])

  @@map("documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}
